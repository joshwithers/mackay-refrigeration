---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { domain } from '../config/site';
---

<Base
  title="Privacy Policy"
  description="Privacy policy for Mky Refrigeration and Air-Conditioning. Basically we store nothing but analytics from users unless they fill out a contract or contact form."
>

  <!-- ── Legal header ── -->
  <div class="legal-header">
    <div class="hero-badge">
      <span class="pulse"></span>
      Legal
    </div>
    <h1>Privacy Policy</h1>
    <p class="legal-last-updated">Last updated — 1 March 2026</p>
  </div>

  <!-- ── Legal body ── -->
  <div class="legal-body">
    <div class="md-content">

      <p>
        Mackay Refrigeration Pty Ltd trading as Mackay Refrigeration and Air-Conditioning
        (ABN&nbsp;32&nbsp;107&nbsp;715&nbsp;766) is committed to protecting your personal
        information in accordance with the <em>Privacy Act 1988</em> (Cth) and the
        Australian Privacy Principles.
      </p>

      <h2>What information we collect</h2>
      <p>
        We collect personal information you provide directly — such as your name, phone
        number, email address, and project details — when you contact us via our website
        form, email, or phone.
      </p>
      <p>
        We do not use cookies for tracking, run advertising networks, or collect
        information about your browsing behaviour.
      </p>

      <h2>How we use your information</h2>
      <p>We use your information to:</p>
      <ul>
        <li>Respond to your enquiry or service request</li>
        <li>Provide and invoice for the services you engage us to perform</li>
        <li>Send service reminders or maintenance schedule notifications where agreed</li>
        <li>Meet our legal and regulatory obligations</li>
      </ul>

      <h2>Disclosure to third parties</h2>
      <p>
        We do not sell, rent, or share your personal information with third parties for
        marketing purposes. We may share information with contractors or suppliers only
        to the extent required to deliver your project.
      </p>

      <h2>Storage and security</h2>
      <p>
        Your information is stored in our business management systems, which are
        password-protected and accessible only by authorised staff. We take reasonable
        steps to protect personal information from misuse, interference, loss,
        unauthorised access, modification, or disclosure.
      </p>

      <h2>Access and correction</h2>
      <p>
        You may request access to, or correction of, any personal information we hold
        about you by contacting us at <a href="mailto:service@mackayrefrig.com.au">service@mackayrefrig.com.au</a>.
        We will respond within a reasonable time and at no charge.
      </p>

      <h2>Contact</h2>
      <p>
        For privacy-related enquiries or complaints, contact us:<br />
        <strong>Mackay Refrigeration Pty Ltd</strong><br />
        P.O. Box 4087, Mackay QLD 4740<br />
        <a href="tel:0749531245">07 4953 1245</a> &nbsp;|&nbsp;
        <a href="mailto:service@mackayrefrig.com.au">service@mackayrefrig.com.au</a>
      </p>

      <hr />

      <p style="font-size: 14px; opacity: 0.5;">
        This policy applies to {domain} and is reviewed periodically.
      </p>

    </div>
  </div>

  <Footer />
</Base>
