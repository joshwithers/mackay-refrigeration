---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
import { formAction } from '../config/site';

const isNetlify = formAction === 'netlify';
const formAttrs = isNetlify
  ? { 'data-netlify': 'true', 'netlify-honeypot': 'bot-field' }
  : { action: formAction };
---

<Base
  title="Contact"
  description="Contact Mackay Refrigeration & Air-Conditioning on 07 4953 1245 for a free quote on cold room builds, air conditioning, commercial refrigeration, post mix, and emergency repairs across Mackay and North Queensland."
>
  <PageHero
    badge="03 — Contact"
    title={`Get in <span class="cold">touch</span>`}
    sub="Free quotes for commercial refrigeration and air conditioning across Mackay, Airlie Beach, Bowen, and Moranbah. Call or fill in the form and we'll get back to you."
  />

  <div class="contact-grid">

    <!-- ── Contact Form ── -->
    <div class="contact-form-col">
      <div class="contact-col-label">Send us a message</div>

      <form name="contact" method="POST" {...formAttrs}>
        {isNetlify && <input type="hidden" name="form-name" value="contact" />}
        {isNetlify && (
          <p class="bot-field" style="display:none">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
        )}

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input class="form-input" type="text" id="name" name="name" placeholder="Jane Smith" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="company">Company <span class="form-optional">(optional)</span></label>
            <input class="form-input" type="text" id="company" name="company" placeholder="Venue or business name" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="phone">Phone</label>
            <input class="form-input" type="tel" id="phone" name="phone" placeholder="07 xxxx xxxx" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="service">Service required</label>
          <select class="form-select" id="service" name="service">
            <option value="" disabled selected>Select a service…</option>
            <option value="cold-room">Cold Room Build</option>
            <option value="freezer-room">Freezer Room Build</option>
            <option value="commercial-refrigeration">Commercial Refrigeration</option>
            <option value="air-conditioning">Air Conditioning</option>
            <option value="beer-post-mix">Beer &amp; Post Mix Systems</option>
            <option value="maintenance">Maintenance / Servicing Contract</option>
            <option value="emergency">Emergency Repair</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="message">Tell us about your project</label>
          <textarea class="form-textarea" id="message" name="message" placeholder="Brief description — size, location, timeline, any specifics we should know…" rows="5"></textarea>
        </div>

        <button type="submit" class="cta-btn" style="width:100%; justify-content:center;">
          Send enquiry
          <svg viewBox="0 0 16 16">
            <path d="M3 8 L13 8 M9 4 L13 8 L9 12"/>
          </svg>
        </button>
      </form>
    </div>

    <!-- ── Business Details ── -->
    <div class="contact-info-col">
      <div class="contact-col-label">Business details</div>

      <div class="contact-detail-block">
        <div class="contact-detail-label">Phone</div>
        <div class="contact-detail-value">
          <a href="tel:0749531245" class="contact-phone-large">07 4953 1245</a>
          <span style="font-family: 'DM Mono', monospace; font-size: 11px; color: var(--green);">24/7 emergency line</span>
        </div>
      </div>

      <div class="contact-detail-block">
        <div class="contact-detail-label">Email</div>
        <div class="contact-detail-value">
          <a href="mailto:service@mackayrefrig.com.au">service@mackayrefrig.com.au</a>
        </div>
      </div>

      <div class="contact-detail-block">
        <div class="contact-detail-label">Postal address</div>
        <div class="contact-detail-value">
          P.O. Box 4087<br />
          Mackay, Queensland 4740
        </div>
      </div>

      <div class="contact-detail-block">
        <div class="contact-detail-label">Business hours</div>
        <div class="hours-table">
          <div class="hours-row">
            <span class="day">Monday – Thursday</span>
            <span>7:30 am – 4:30 pm</span>
          </div>
          <div class="hours-row">
            <span class="day">Friday</span>
            <span>7:30 am – 2:00 pm</span>
          </div>
          <div class="hours-row">
            <span class="day">Saturday – Sunday</span>
            <span class="closed">Closed</span>
          </div>
        </div>
      </div>

      <div class="contact-detail-block">
        <div class="contact-detail-label">Service area</div>
        <div class="service-area-tags">
          <span class="service-area-tag primary">Mackay</span>
          <span class="service-area-tag">Airlie Beach</span>
          <span class="service-area-tag">Cannonvale</span>
          <span class="service-area-tag">Bowen</span>
          <span class="service-area-tag">Moranbah</span>
        </div>
      </div>

      <div class="contact-detail-block" style="margin-bottom: 0;">
        <div class="contact-detail-label">Licences</div>
        <div class="licence-list">
          <span>QBCC 15026021</span>
          <span>Arctick AU00021</span>
          <span>ABN 32 107 715 766</span>
        </div>
      </div>
    </div>

  </div><!-- /contact-grid -->

  <Footer />
</Base>
