  <div class="hire-form-section">

    <div class="hire-form-heading">
      <div class="hero-badge">
        <span class="pulse"></span>
        Agreement
      </div>
      <h2>Customer Agreement Form</h2>
      <p class="hire-form-sub">
        Complete all fields below. By submitting this form the Customer and Guarantor(s) confirm that they have
        read, understood, and agree to the Terms and Conditions set out above, executed as a Deed.
      </p>
    </div>

    <form name="terms-agreement" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="terms-agreement" />
      <p style="display:none"><label>Don't fill this in: <input name="bot-field" /></label></p>

      <!-- ── Agreement date ── -->
      <div class="hire-fieldset">
        <span class="hire-fieldset-legend">Agreement date</span>
        <div class="hire-fieldset-body">
          <div class="form-group">
            <label class="form-label" for="agreement-date">Date of agreement</label>
            <input class="form-input" type="date" id="agreement-date" name="agreement_date" required />
          </div>
        </div>
      </div>

      <!-- ── Customer details ── -->
      <div class="hire-fieldset">
        <span class="hire-fieldset-legend">Customer details</span>
        <div class="hire-fieldset-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="customer-company">Business / company name</label>
              <input class="form-input" type="text" id="customer-company" name="customer_company"
                placeholder="Legal entity name" required autocomplete="organization" />
            </div>
            <div class="form-group">
              <label class="form-label" for="customer-abn">ABN <span style="opacity:0.45">(optional)</span></label>
              <input class="form-input" type="text" id="customer-abn" name="customer_abn"
                placeholder="e.g. 12 345 678 901" autocomplete="off" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="customer-name">Authorised representative name</label>
              <input class="form-input" type="text" id="customer-name" name="customer_name"
                placeholder="Full name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label class="form-label" for="customer-capacity">Capacity / position</label>
              <input class="form-input" type="text" id="customer-capacity" name="customer_capacity"
                placeholder="e.g. Director, Manager" required autocomplete="organization-title" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="customer-email">Email address</label>
              <input class="form-input" type="email" id="customer-email" name="customer_email"
                placeholder="you@example.com" required autocomplete="email" />
            </div>
