---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { url } from '../config/site';
---

<Base
  title="Services"
  description="Cold room builds, freezer rooms, commercial refrigeration, air conditioning, beer and post mix systems, maintenance, and 24/7 emergency repairs across Mackay and North Queensland."
>
  <PageHero
    badge="02 — Services"
    title={`Everything you need,<br /><span class="cold">cold and cool</span>`}
    sub="From cold room builds to air conditioning installs — we design, supply, install, and maintain the full commercial refrigeration and HVAC scope across Mackay and North Queensland."
  />

  <div class="service-sections">

    <!-- ── 01 Cold Rooms & Freezer Rooms ── -->
    <div class="service-section reveal">
      <div class="service-section-meta">
        <div class="service-section-number">01</div>
        <div class="service-section-icon">
          <svg viewBox="0 0 48 48">
            <rect x="8" y="6" width="32" height="36" rx="3"/>
            <line x1="8" y1="18" x2="40" y2="18"/>
            <line x1="8" y1="30" x2="40" y2="30"/>
            <circle cx="24" cy="12" r="3"/>
          </svg>
        </div>
        <h2>Cold Rooms &amp;<br />Freezer Rooms</h2>
        <a href={url('/contact')} class="section-cta" style="margin-top: auto;">
          Get a quote
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
      <div class="service-section-body">
        <p>
          Custom-designed and built to suit your operation. Whether you need a small coolroom for a café, a large walk-in freezer for a seafood processor, or a purpose-built cool store for primary produce — we design, supply, install, and commission the complete system. One contractor, start to finish.
        </p>
        <p>
          We work with insulated panel suppliers, refrigeration equipment manufacturers, and electrical contractors to deliver a fully integrated room that meets your temperature requirements and food safety obligations.
        </p>
        <ul class="spec-list">
          <li>Temperatures from +10°C to −30°C</li>
          <li>Custom dimensions and configurations</li>
          <li>Insulated panel floors, walls, and ceilings</li>
          <li>Glass door and solid door options</li>
          <li>Remote and on-site condensing units</li>
          <li>Blast chilling and quick-freeze systems</li>
          <li>Refrigerants: R448A, R449A, R134a, R290</li>
          <li>Temperature monitoring and alarms</li>
        </ul>
        <a href="tel:0749531245" class="section-cta">
          Call 07 4953 1245
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
    </div>

    <!-- ── 02 Commercial Refrigeration ── -->
    <div class="service-section reveal">
      <div class="service-section-meta">
        <div class="service-section-number">02</div>
        <div class="service-section-icon">
          <svg viewBox="0 0 48 48">
            <path d="M24 4 L24 44 M16 10 L24 18 L32 10 M16 38 L24 30 L32 38 M4 24 L44 24 M10 16 L18 24 L10 32 M38 16 L30 24 L38 32"/>
          </svg>
        </div>
        <h2>Commercial Refrigeration</h2>
        <a href="tel:0749531245" class="section-cta" style="margin-top: auto;">
          Call us
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
      <div class="service-section-body">
        <p>
          Supply, installation, and ongoing maintenance of commercial refrigeration equipment for hospitality, retail, food service, and industry. We work with quality brands and specify the right unit for your application — not just whatever's in the warehouse.
        </p>
        <p>
          All installations are commissioned and documented to meet food safety and workplace compliance requirements. We also maintain equipment we didn't install — if it runs on refrigerant, we can service it.
        </p>
        <ul class="spec-list">
          <li>Display cabinets and multi-deck cases</li>
          <li>Back-bar coolers and bottle displays</li>
          <li>Under-bench and undercounter refrigeration</li>
          <li>Island freezers and chest freezers</li>
          <li>Cellar and cool room systems</li>
          <li>Refrigerated prep tables</li>
          <li>Ice makers and ice storage</li>
          <li>Refrigerant top-up and leak testing</li>
        </ul>
        <a href="tel:0749531245" class="section-cta">
          Call 07 4953 1245
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
    </div>

    <!-- ── 03 Commercial Air Conditioning ── -->
    <div class="service-section reveal">
      <div class="service-section-meta">
        <div class="service-section-number">03</div>
        <div class="service-section-icon">
          <svg viewBox="0 0 48 48">
            <rect x="6" y="14" width="36" height="20" rx="3"/>
            <path d="M12 8 L12 14 M24 8 L24 14 M36 8 L36 14"/>
            <path d="M10 28 Q16 24 22 28 Q28 32 34 28 Q38 26 40 24"/>
          </svg>
        </div>
        <h2>Commercial Air Conditioning</h2>
        <a href={url('/contact')} class="section-cta" style="margin-top: auto;">
          Book a site assessment
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
      <div class="service-section-body">
        <p>
          Supply, installation, and maintenance of commercial air conditioning systems. We size systems correctly for the space and usage — offices, retail, hospitality, and industrial. In the Mackay climate, getting the specification right matters.
        </p>
        <p>
          We install and service all major brands, and can set up annual service contracts so your system stays compliant and efficient year-round. All refrigerant work is handled by Arctick-licensed technicians.
        </p>
        <ul class="spec-list">
          <li>Wall-mounted split systems</li>
          <li>Ceiling cassette units</li>
          <li>Ducted commercial systems</li>
          <li>Multi-head and multi-split systems</li>
          <li>VRF/VRV systems</li>
          <li>Refrigerant handling (Arctick AU00021)</li>
          <li>Annual service agreements</li>
          <li>Filter cleaning and coil servicing</li>
        </ul>
        <a href="tel:0749531245" class="section-cta">
          Call 07 4953 1245
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
    </div>

    <!-- ── 04 Beer & Post Mix Systems ── -->
    <div class="service-section reveal">
      <div class="service-section-meta">
        <div class="service-section-number">04</div>
        <div class="service-section-icon">
          <svg viewBox="0 0 48 48">
            <rect x="14" y="4" width="20" height="28" rx="4"/>
            <path d="M18 32 L16 44 M30 32 L32 44"/>
            <line x1="10" y1="44" x2="38" y2="44"/>
            <path d="M34 14 L38 14 Q42 14 42 18 L42 24 Q42 28 38 28 L34 28"/>
          </svg>
        </div>
        <h2>Beer &amp; Post Mix Systems</h2>
        <a href={url('/contact')} class="section-cta" style="margin-top: auto;">
          Get a quote
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
      <div class="service-section-body">
        <p>
          Complete reticulation system design, installation, and maintenance for licensed venues. We keep the drinks flowing and the lines clean — from keg room refrigeration to bar tap installation and post mix calibration.
        </p>
        <p>
          Whether you're fitting out a new venue or troubleshooting an existing system, we know what a well-run bar system looks like and can get yours there.
        </p>
        <ul class="spec-list">
          <li>Beer reticulation design and installation</li>
          <li>Python and line cleaning</li>
          <li>CO₂ and gas system installation</li>
          <li>Post mix installation and calibration</li>
          <li>Keg room refrigeration</li>
          <li>Glycol chiller systems</li>
          <li>Tap and font equipment</li>
          <li>Preventive maintenance contracts</li>
        </ul>
        <a href="tel:0749531245" class="section-cta">
          Call 07 4953 1245
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
    </div>

    <!-- ── 05 Maintenance & Servicing ── -->
    <div class="service-section reveal">
      <div class="service-section-meta">
        <div class="service-section-number">05</div>
        <div class="service-section-icon">
          <svg viewBox="0 0 48 48">
            <circle cx="24" cy="24" r="16"/>
            <path d="M24 12 L24 24 L32 28"/>
            <circle cx="24" cy="24" r="3"/>
          </svg>
        </div>
        <h2>Maintenance &amp; Servicing</h2>
        <a href={url('/contact')} class="section-cta" style="margin-top: auto;">
          Set up a contract
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
      <div class="service-section-body">
        <p>
          A regular service schedule is the most cost-effective way to keep your refrigeration and air conditioning running. We offer scheduled maintenance contracts designed around your equipment and operating hours.
        </p>
        <p>
          All refrigerant work is performed by Arctick-licensed technicians. We provide full compliance documentation for your food safety management system and licence audits.
        </p>
        <ul class="spec-list">
          <li>Refrigerant level and pressure checks</li>
          <li>Coil and filter cleaning</li>
          <li>Electrical and safety inspections</li>
          <li>Arctick compliance certificates</li>
          <li>Temperature accuracy verification</li>
          <li>Door seal and gasket inspection</li>
          <li>Defrost cycle verification</li>
          <li>Written service reports</li>
        </ul>
        <a href="tel:0749531245" class="section-cta">
          Call 07 4953 1245
          <svg viewBox="0 0 16 16"><path d="M3 8 L13 8 M9 4 L13 8 L9 12"/></svg>
        </a>
      </div>
    </div>

  </div><!-- /service-sections -->

  <!-- Emergency Callout Banner -->
  <div class="emergency-banner reveal">
    <div class="emergency-banner-text">
      <h3>24/7 Emergency Repairs</h3>
      <p>
        Compressor failures, refrigerant leaks, electrical faults. When your cold chain fails, we respond — across Mackay, Airlie Beach, Bowen, and Moranbah.
      </p>
    </div>
    <a href="tel:0749531245" class="emergency-number">07 4953 1245</a>
  </div>

  <CTA />
  <Footer />
</Base>
