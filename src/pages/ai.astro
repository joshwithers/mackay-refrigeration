---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { fullUrl, siteConfig } from '../config/site';

const blog = await getCollection('blog');
const reviews = await getCollection('reviews');

const sortedBlog = blog.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedReviews = reviews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const avgRating = (sortedReviews.reduce((sum, r) => sum + r.data.rating, 0) / sortedReviews.length).toFixed(1);

const buildDate = new Date().toISOString().split('T')[0];

const resources = [
  {
    title: 'llms.txt',
    url: fullUrl('/llms.txt'),
    description: 'Summary context file following the llmstxt.org specification. Includes business info, services, page index, blog summaries, and review ratings. Designed for LLM consumption.',
    format: 'Plain text (Markdown)',
    spec: 'https://llmstxt.org',
  },
  {
    title: 'llms-full.txt',
    url: fullUrl('/llms-full.txt'),
    description: 'Full-content version of llms.txt. Includes complete blog post content, full customer review text, detailed service specifications, and structured data summary.',
    format: 'Plain text (Markdown)',
    spec: 'https://llmstxt.org',
  },
  {
    title: 'sitemap-index.xml',
    url: fullUrl('/sitemap-index.xml'),
    description: 'XML sitemap index generated by @astrojs/sitemap. Lists all public pages with last-modified dates for search engine crawlers.',
    format: 'XML (Sitemap Protocol)',
    spec: 'https://www.sitemaps.org/protocol.html',
  },
  {
    title: 'robots.txt',
    url: fullUrl('/robots.txt'),
    description: 'Robots exclusion protocol file. Currently allows all crawlers full access. References sitemap and llms.txt locations.',
    format: 'Plain text',
    spec: 'https://www.robotstxt.org/robotstxt.html',
  },
  {
    title: 'RSS Feed',
    url: fullUrl('/rss.xml'),
    description: 'RSS 2.0 feed of all blog posts with titles, descriptions, publication dates, and full content.',
    format: 'XML (RSS 2.0)',
    spec: 'https://www.rssboard.org/rss-specification',
  },
];

const schemaFields = [
  { field: '@type', value: 'LocalBusiness' },
  { field: 'name', value: 'Mackay Refrigeration & Air-Conditioning' },
  { field: 'telephone', value: '+61749531245' },
  { field: 'email', value: 'service@mackayrefrig.com.au' },
  { field: 'address', value: 'PO Box 4087, Mackay QLD 4740, AU' },
  { field: 'areaServed', value: 'Mackay, Airlie Beach, Bowen, Moranbah' },
  { field: 'ABN', value: '32 107 715 766' },
];
---

<Base
  title="For AI & Bots — Machine-Readable Resources"
  description="Index of machine-readable resources for AI crawlers, LLMs, and search engines. Includes llms.txt, sitemap, RSS, robots.txt, and structured data."
>

  <div class="page-layout-header">
    <div class="hero-badge">
      <span class="pulse"></span>
      For AI &amp; Bots
    </div>
    <h1>Machine-readable<br /><span class="cold">resources</span></h1>
    <p class="hero-sub">
      Everything crawlers, LLMs, and search engines need to understand this website.
      All files are generated at build time from live content collections.
    </p>
  </div>

  <div class="page-body">
    <div class="md-content">

      <p>
        This page indexes all machine-readable resources available on
        <strong>{siteConfig.url}</strong>. Every file listed below is generated
        at build time from the site's content collections and configuration — no
        static copies, no stale data.
      </p>

      <p style="font-family: 'DM Mono', monospace; font-size: 12px; color: var(--frost); letter-spacing: 0.05em;">
        Last build: {buildDate} · {sortedBlog.length} blog posts · {sortedReviews.length} reviews (avg {avgRating}/5)
      </p>

      <h2>Resource Index</h2>

      <div class="ai-resources">
        {resources.map((r) => (
          <div class="ai-resource-card">
            <div class="ai-resource-header">
              <a href={r.url} class="ai-resource-title">{r.title}</a>
              <span class="ai-resource-format">{r.format}</span>
            </div>
            <p class="ai-resource-desc">{r.description}</p>
            <div class="ai-resource-links">
              <a href={r.url}>View file</a>
              <span>·</span>
              <a href={r.spec} target="_blank" rel="noopener">Specification</a>
            </div>
          </div>
        ))}
      </div>

      <h2>Structured Data (Schema.org)</h2>

      <p>
        Every page on this site includes a <code>LocalBusiness</code> JSON-LD
        schema in the <code>&lt;head&gt;</code>. This structured data is embedded
        at build time and includes:
      </p>

      <table>
        <thead>
          <tr>
            <th>Field</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          {schemaFields.map((f) => (
            <tr>
              <td><code>{f.field}</code></td>
              <td>{f.value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <p>
        Opening hours are specified per day-of-week using <code>OpeningHoursSpecification</code>.
        The full schema can be extracted from the <code>&lt;script type="application/ld+json"&gt;</code>
        tag on any page, or from the <a href={fullUrl('/llms-full.txt')}>llms-full.txt</a> file.
      </p>

      <h2>Content Collections</h2>

      <p>
        The site uses two Astro content collections, both included in the llms.txt files:
      </p>

      <h3>Blog ({sortedBlog.length} posts)</h3>

      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Published</th>
          </tr>
        </thead>
        <tbody>
          {sortedBlog.map((post) => (
            <tr>
              <td><a href={fullUrl(`/blog/${post.id}`)}>{post.data.title}</a></td>
              <td>{post.data.pubDate.toISOString().split('T')[0]}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3>Reviews ({sortedReviews.length} reviews · avg {avgRating}/5)</h3>

      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Location</th>
            <th>Rating</th>
          </tr>
        </thead>
        <tbody>
          {sortedReviews.map((r) => (
            <tr>
              <td>{r.data.name}</td>
              <td>{r.data.address}</td>
              <td>{r.data.rating}/5</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Page Inventory</h2>

      <p>
        All public pages on this site, with their purpose:
      </p>

      <table>
        <thead>
          <tr>
            <th>Path</th>
            <th>Purpose</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>/</code></td><td>Homepage — services overview, stats, CTA</td></tr>
          <tr><td><code>/about</code></td><td>Company background, service area, licences</td></tr>
          <tr><td><code>/services</code></td><td>Detailed breakdown of all six service categories</td></tr>
          <tr><td><code>/contact</code></td><td>Contact form, phone, email, business hours</td></tr>
          <tr><td><code>/reviews</code></td><td>Customer testimonials</td></tr>
          <tr><td><code>/blog</code></td><td>Technical articles on commercial refrigeration</td></tr>
          <tr><td><code>/blog/[slug]</code></td><td>Individual blog posts</td></tr>
          <tr><td><code>/privacy</code></td><td>Privacy policy</td></tr>
          <tr><td><code>/terms</code></td><td>Terms and conditions for supply of equipment/services</td></tr>
          <tr><td><code>/hire-contract</code></td><td>Equipment hire conditions and agreement form</td></tr>
          <tr><td><code>/ai</code></td><td>This page — machine-readable resource index</td></tr>
        </tbody>
      </table>

      <h2>Crawling Guidelines</h2>

      <p>
        All pages and resources are freely crawlable. There are no restricted
        paths in <a href={fullUrl('/robots.txt')}>robots.txt</a>. The site is statically
        generated (Astro SSG) so all content is available in the initial HTML
        response — no JavaScript rendering required for content extraction.
      </p>

      <p>
        For the most efficient LLM context loading, use <a href={fullUrl('/llms.txt')}>llms.txt</a>
        for a summary or <a href={fullUrl('/llms-full.txt')}>llms-full.txt</a> for complete content
        including full blog post text and review content.
      </p>

    </div>
  </div>

  <Footer />
</Base>
