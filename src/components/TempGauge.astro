---
// TempGauge.astro — Fixed sidebar temperature indicator
// JS is handled in Base.astro (runs after all content is rendered)
---

<div class="temp-gauge" id="tempGauge" aria-hidden="true">
  <span class="label">Temp</span>
  <div class="bar-track">
    <div class="bar-fill" id="tempFill"></div>
  </div>
  <span class="reading" id="tempReading">+2°C</span>
</div>
