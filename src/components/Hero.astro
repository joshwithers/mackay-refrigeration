---
// Hero.astro — Full-viewport hero with frost SVG overlay and blueprint unit
---

<section class="hero" aria-labelledby="hero-heading">
  <!-- Frost crystal SVG overlay — decorative, do not edit paths -->
  <svg class="frost-overlay" viewBox="0 0 1440 900" preserveAspectRatio="none" aria-hidden="true" focusable="false">
    <path class="frost-line frost-line-1" d="M0,450 Q200,400 400,420 T800,380 T1200,410 T1440,390" />
    <path class="frost-line frost-line-2" d="M-50,500 Q150,520 350,480 T750,500 T1100,470 T1440,490" />
    <path class="frost-line frost-line-3" d="M0,350 Q300,330 500,360 T900,340 T1440,355" />
    <path class="frost-line frost-line-4" d="M1440,200 Q1200,250 1000,220 T600,260 T200,230 T0,250" />
    <path class="frost-line frost-line-5" d="M1440,650 Q1100,620 900,660 T500,630 T100,660 T0,640" />
  </svg>

  <p class="hero-badge">
    <span class="pulse" aria-hidden="true"></span>
    Commercial Refrigeration &amp; Air-Con — Mackay, QLD
  </p>

  <h1 id="hero-heading" class="hero-display">Precision<br /><span class="cold">cold</span> systems<br />engineered to last</h1>

  <p class="hero-sub">
    Cool rooms, freezer systems, air conditioning, and cold chain solutions for
    commercial operations across Mackay and North Queensland. Designed, installed,
    and maintained.
  </p>

  <!-- Blueprint refrigeration unit — decorative, do not edit SVG paths -->
  <div class="hero-unit" aria-hidden="true">
    <svg class="unit-svg" viewBox="0 0 380 480" focusable="false">
      <defs>
        <filter id="glow">
          <feGaussianBlur stdDeviation="4" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      <!-- Main cabinet outline -->
      <rect class="unit-line unit-draw" x="40" y="60" width="300" height="380" rx="4"/>
      <!-- Door split -->
      <line class="unit-line unit-draw" x1="190" y1="60" x2="190" y2="440"/>
      <!-- Handle left -->
      <line class="unit-line unit-draw" x1="170" y1="200" x2="170" y2="260" style="stroke-width:2"/>
      <!-- Handle right -->
      <line class="unit-line unit-draw" x1="210" y1="200" x2="210" y2="260" style="stroke-width:2"/>
      <!-- Top grille -->
      <rect class="unit-line unit-draw" x="60" y="20" width="260" height="30" rx="2"/>
      <line class="unit-line unit-draw" x1="120" y1="20" x2="120" y2="50"/>
      <line class="unit-line unit-draw" x1="190" y1="20" x2="190" y2="50"/>
      <line class="unit-line unit-draw" x1="260" y1="20" x2="260" y2="50"/>
      <!-- Compressor base -->
      <rect class="unit-line unit-draw" x="60" y="445" width="260" height="25" rx="2"/>
      <!-- Internal shelves (visible through door gap) -->
      <line class="unit-line unit-draw" x1="50" y1="160" x2="180" y2="160" style="opacity:0.4"/>
      <line class="unit-line unit-draw" x1="200" y1="160" x2="330" y2="160" style="opacity:0.4"/>
      <line class="unit-line unit-draw" x1="50" y1="280" x2="180" y2="280" style="opacity:0.4"/>
      <line class="unit-line unit-draw" x1="200" y1="280" x2="330" y2="280" style="opacity:0.4"/>
      <line class="unit-line unit-draw" x1="50" y1="370" x2="180" y2="370" style="opacity:0.4"/>
      <line class="unit-line unit-draw" x1="200" y1="370" x2="330" y2="370" style="opacity:0.4"/>

      <!-- Fan unit top -->
      <g class="fan-group">
        <circle class="fan-blade" cx="190" cy="140" r="18"/>
        <line class="fan-blade" x1="190" y1="122" x2="190" y2="158"/>
        <line class="fan-blade" x1="172" y1="140" x2="208" y2="140"/>
        <line class="fan-blade" x1="177" y1="127" x2="203" y2="153"/>
        <line class="fan-blade" x1="203" y1="127" x2="177" y2="153"/>
      </g>

      <!-- Coolant lines -->
      <path class="coolant-flow flowing" d="M60,455 Q60,475 80,475 L300,475 Q320,475 320,455"/>
      <path class="coolant-flow flowing" d="M80,475 L80,490 Q80,495 85,495 L295,495 Q300,495 300,490 L300,475"/>

      <!-- Glow elements -->
      <rect class="unit-glow" x="50" y="70" width="130" height="160" rx="2"/>
      <rect class="unit-glow" x="200" y="70" width="130" height="160" rx="2"/>

      <!-- Dimension labels -->
      <line class="dim-line" x1="20" y1="60" x2="20" y2="440"/>
      <text class="dim-label" x="8" y="255" transform="rotate(-90 8 255)">1800mm</text>
      <line class="dim-line" x1="40" y1="475" x2="340" y2="475"/>
      <text class="dim-label" x="170" y="488">1200mm</text>

      <!-- Status indicator -->
      <circle cx="325" cy="75" r="4" fill="var(--green)" opacity="0" style="animation: fade-in 0.3s ease 4.5s forwards">
        <animate attributeName="opacity" values="0.5;1;0.5" dur="2s" repeatCount="indefinite" begin="4.5s"/>
      </circle>
      <text class="dim-label" x="280" y="79" style="animation-delay: 4.5s">ONLINE</text>
    </svg>
  </div>
</section>
